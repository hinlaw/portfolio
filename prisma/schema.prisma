// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// AI Expense 用戶設定 (可擴充多種 preferences)
model AiExpenseSettings {
  id          String   @id @default(cuid())
  ownerId     String   @unique // 未來可接 Clerk userId，目前可用 "default"
  receiptLanguage String? @default("en") // en | zh | zh_HK | receipt
  preferences Json?    @default("{}")     // 擴充用：{ key: value }
  updatedAt   DateTime @updatedAt
}

// 單據 Table
model Expense {
  id             String   @id @default(cuid())
  merchant       String?  // 商戶名稱 (例如: 7-Eleven)
  amount         Float?   // 金額 (例如: 105.5)
  originalAmount Float?   // 原幣金額
  date           String?  // 日期 YYYY-MM-DD
  currency       String?  @default("USD")
  exchangeRate   Float?   @default(1)
  media          String[] @default([])  // 圖片/文件 URL 陣列，最多 10 個
  description    String?
  workspaceId    String?
  createdAt      DateTime @default(now())
}
