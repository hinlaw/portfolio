// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// AI Expense 用戶設定 (可擴充多種 preferences)
model AiExpenseSettings {
  id          String   @id @default(cuid())
  ownerId     String   @unique // 未來可接 Clerk userId，目前可用 "default"
  receiptLanguage String? @default("en") // en | zh | zh_HK | receipt
  preferences Json?    @default("{}")     // 擴充用：{ key: value }
  updatedAt   DateTime @updatedAt
}

// Workspace - 每個 workspace 有獨立的基礎幣別、收據輸出語言與單據
model Workspace {
  id              String   @id @default(cuid())
  name            String   // 顯示名稱
  baseCurrency    String   @default("USD") // USD | CNY | HKD
  receiptLanguage String?  @default("en")   // en | zh | zh_HK | receipt
  ownerId         String   @default("default") // 未來可接 Clerk userId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expenses        Expense[]

  @@index([ownerId])
}

// 單據 Table
model Expense {
  id             String    @id @default(cuid())
  merchant       String?   // 商戶名稱 (例如: 7-Eleven)
  amount         Float?    // 金額 (儲存於 workspace 的 baseCurrency)
  originalAmount Float?    // 原幣金額
  date           String?   // 日期 YYYY-MM-DD
  currency       String?   @default("USD")
  exchangeRate   Float?    @default(1)
  media          String[]  @default([])  // 圖片/文件 URL 陣列，最多 10 個
  description    String?
  workspaceId    String?   // 關聯至 Workspace
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())

  @@index([workspaceId])
}
